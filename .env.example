# Modelo de variaveis de ambiente do ReelRate (versionado).
# Copie para .env.local (runtime do Next) e .env (CLI do Prisma) e preencha.

# Banco de dados (Postgres). Local via Docker, ou Vercel Postgres em producao.
# (porta 5433 no host para evitar conflito com Postgres nativo na 5432 — ver docker-compose.yml)
POSTGRES_PRISMA_URL="postgresql://reelrate:reelrate@localhost:5433/reelrate?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://reelrate:reelrate@localhost:5433/reelrate?schema=public"

# NextAuth
# Gere um segredo: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# TMDB (chave v3) — apenas no servidor
TMDB_API_KEY=""
TMDB_BASE_URL="https://api.themoviedb.org/3"
